{
  "project": "html-brick-game",
  "baseUrl": "https://chanmeng666.github.io/html-brick-game/",
  "outDir": "docs/showcase",

  "viewports": {
    "desktop": { "width": 1280, "height": 800, "deviceScaleFactor": 2 },
    "mobile":  { "width": 390,  "height": 844, "deviceScaleFactor": 3, "isMobile": true }
  },

  "reducedMotion": "reduce",

  "pages": [
    {
      "label": "title",
      "url": "./",
      "viewport": "desktop",
      "fullPage": false,
      "before": [
        { "action": "wait", "ms": 2500 }
      ]
    },
    {
      "label": "game-playing",
      "url": "./",
      "viewport": "desktop",
      "fullPage": false,
      "before": [
        { "action": "wait", "ms": 2500 },
        { "action": "evaluate", "script": "document.getElementById('startGameBtn').click()" },
        { "action": "wait", "ms": 2000 }
      ]
    },
    {
      "label": "instructions",
      "url": "./",
      "viewport": "desktop",
      "fullPage": false,
      "before": [
        { "action": "wait", "ms": 2500 },
        { "action": "evaluate", "script": "document.getElementById('instructionsBtn').click()" },
        { "action": "wait", "ms": 1200 }
      ]
    },
    {
      "label": "mobile-title",
      "url": "./",
      "viewport": "mobile",
      "fullPage": false,
      "before": [
        { "action": "wait", "ms": 2500 }
      ]
    }
  ],

  "demo": {
    "size": { "width": 1280, "height": 720 },
    "stepPauseMs": 400,
    "steps": [
      { "action": "goto", "url": "./", "timeoutMs": 15000 },
      { "action": "wait", "ms": 1500 },
      { "action": "evaluate", "script": "document.getElementById('instructionsBtn').click()" },
      { "action": "wait", "ms": 1500 },
      { "action": "evaluate", "script": "document.getElementById('backToMenuBtn').click()" },
      { "action": "wait", "ms": 800 },
      { "action": "evaluate", "script": "document.getElementById('startGameBtn').click()" },
      { "action": "wait", "ms": 2500 }
    ]
  }
}
